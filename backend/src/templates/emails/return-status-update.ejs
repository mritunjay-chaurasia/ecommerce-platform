<%- include('partials/header', { storeName, title: 'Return Update' }) %>

<h2 style="margin:0 0 16px;font-size:18px;">Return request update</h2>
<p style="margin:0 0 16px;line-height:1.6;">Your return request for order <strong><%= orderNumber %></strong> is now <strong><%= statusLabel %></strong>.</p>
<% if (adminNotes) { %>
<p style="margin:0 0 16px;line-height:1.6;color:#52525b;">Note from support: <%= adminNotes %></p>
<% } %>
<p style="margin:0;line-height:1.6;color:#71717a;font-size:14px;">If you have questions, contact us at <%= supportEmail || 'support' %>.</p>

<%- include('partials/footer', { storeName }) %>
