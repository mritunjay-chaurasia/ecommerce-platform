<%- include('partials/header', { storeName, title: 'Verify Email' }) %>

<h2 style="margin:0 0 16px;font-size:18px;">Verify your email address</h2>
<p style="margin:0 0 16px;line-height:1.6;">Hi <%= customerName %>, thanks for signing up at <%= storeName %>. Please confirm your email to secure your account.</p>
<p style="margin:0 0 24px;">
  <a href="<%= verifyUrl %>" style="display:inline-block;padding:12px 24px;background:#18181b;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;">Verify Email</a>
</p>
<p style="margin:0 0 8px;line-height:1.6;color:#71717a;font-size:14px;">This link expires in <%= expiryHours %> hours.</p>
<p style="margin:0;line-height:1.6;color:#71717a;font-size:14px;">If you did not create this account, you can ignore this email.</p>

<%- include('partials/footer', { storeName }) %>
