<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:16px 0;">
  <% items.forEach(function(item) { %>
    <tr>
      <td style="padding:8px 0;border-bottom:1px solid #e4e4e7;"><%= item.productName %> × <%= item.quantity %></td>
      <td style="padding:8px 0;border-bottom:1px solid #e4e4e7;text-align:right;"><%= formatMoney(item.lineTotal, currency) %></td>
    </tr>
  <% }); %>
</table>
