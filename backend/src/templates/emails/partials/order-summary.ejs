<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:16px;">
  <tr>
    <td style="padding:4px 0;">Subtotal</td>
    <td style="padding:4px 0;text-align:right;"><%= formatMoney(order.subtotal, currency) %></td>
  </tr>
  <tr>
    <td style="padding:4px 0;">Shipping</td>
    <td style="padding:4px 0;text-align:right;"><%= formatMoney(order.shippingFee, currency) %></td>
  </tr>
  <tr>
    <td style="padding:4px 0;">Tax</td>
    <td style="padding:4px 0;text-align:right;"><%= formatMoney(order.taxAmount, currency) %></td>
  </tr>
  <% if (order.discountAmount > 0) { %>
    <tr>
      <td style="padding:4px 0;">Discount</td>
      <td style="padding:4px 0;text-align:right;">-<%= formatMoney(order.discountAmount, currency) %></td>
    </tr>
  <% } %>
  <tr>
    <td style="padding:8px 0;font-weight:600;">Total</td>
    <td style="padding:8px 0;text-align:right;font-weight:600;"><%= formatMoney(order.totalAmount, currency) %></td>
  </tr>
</table>
