<%- include('partials/header', { storeName, title: 'Password Reset' }) %>

<h2 style="margin:0 0 16px;font-size:18px;">Reset your password</h2>
<p style="margin:0 0 16px;line-height:1.6;">We received a request to reset your password. Click the button below to choose a new one.</p>
<p style="margin:0 0 24px;">
  <a href="<%= resetUrl %>" style="display:inline-block;padding:12px 24px;background:#18181b;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;">Reset Password</a>
</p>
<p style="margin:0 0 8px;line-height:1.6;color:#71717a;font-size:14px;">This link expires in <%= expiryMinutes %> minutes.</p>
<p style="margin:0;line-height:1.6;color:#71717a;font-size:14px;">If you did not request this, you can safely ignore this email.</p>

<%- include('partials/footer', { storeName }) %>
